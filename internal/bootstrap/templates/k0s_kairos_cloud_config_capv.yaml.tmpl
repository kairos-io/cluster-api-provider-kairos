#cloud-config

{{- /* 
Template inputs (from Go):

  .Role              string   // "control-plane" or "worker"
  .SingleNode        bool     // true for single-node k0s (controller-only)
  .Hostname          string   // explicit hostname (optional)
  .UserName          string   // e.g. "kairos"
  .UserPassword      string   // e.g. "kairos"
  .UserGroups        []string // e.g. ["admin"]
  .GitHubUser        string   // e.g. "YOUR_GITHUB_USER" (optional)
  .SSHPublicKey      string   // alternative to GitHubUser (optional)
  .WorkerToken       string   // used only for workers
  .Manifests         []Manifest // optional manifests
  .HostnamePrefix    string   // e.g. "metal-"
  .DNSServers        []string // optional DNS resolvers
  .Install           *InstallConfig // install configuration (optional)
  .ProviderID        string   // providerID for Node (e.g., "vsphere://<vm-uuid>")
*/ -}}

{{/* Hostname: prefer explicit name, else use hostname prefix with Kairos templating for machine ID */}}
{{/* The {{ trunc 4 .MachineID }} is Kairos templating syntax, output literally */}}
{{- if .Hostname }}
hostname: {{ .Hostname | quote }}
{{- else if .HostnamePrefix }}
hostname: {{ printf "%s{{ trunc 4 .MachineID }}" .HostnamePrefix | quote }}
{{- end }}

{{- if .Install }}
install:
  auto: {{ .Install.Auto }}
  device: {{ .Install.Device | quote }}
  reboot: {{ .Install.Reboot }}
{{- end }}

users:
- name: {{ .UserName | quote }}
  {{- if .UserPassword }}
  passwd: {{ .UserPassword | quote }}
  {{- end }}
  groups:
  {{- range .UserGroups }}
    - {{ . | quote }}
  {{- end }}
  {{- if or .GitHubUser .SSHPublicKey }}
  ssh_authorized_keys:
  {{- if .GitHubUser }}
    - {{ printf "github:%s" .GitHubUser | quote }}
  {{- end }}
  {{- if .SSHPublicKey }}
    - {{ .SSHPublicKey | quote }}
  {{- end }}
  {{- end }}
- name: capk
  groups: [users, admin]

{{- if eq .Role "control-plane" }}

# Control-plane node configuration
{{- if .IsInitControlPlane }}
# ADR 0005 (HA) init node: k0s controller with managed etcd (no --single). The
# api.sans in /etc/k0s/k0s.yaml MUST include the stable control-plane endpoint
# so the apiserver serving cert is valid for the VIP / InfraCluster endpoint.
{{- else if .IsJoinControlPlane }}
# ADR 0005 (HA) join node: k0s controller-join via --token-file. The token is
# produced on the init controller (k0s token create --role=controller) and
# delivered by the Phase-3 controller through .JoinToken (TOKEN-INV). The join
# target is k0s's own gossip/etcd peer discovery seeded by the token, NOT the
# VIP block.
{{- end }}
k0s:
  enabled: true
  {{- if or .SingleNode .PodCIDR .ServiceCIDR .ProviderID .IsHAControlPlane }}
  args:
  {{- if .SingleNode }}
    - --single
  {{- end }}
  {{- if or .PodCIDR .ServiceCIDR .IsInitControlPlane }}
    - --config /etc/k0s/k0s.yaml
  {{- end }}
  {{- if .IsJoinControlPlane }}
    # Controller-join: --token-file carries the controller-role join token.
    - --token-file=/etc/k0s/controller-token
  {{- end }}
  {{- if .RenderKubeVIP }}
    # ADR 0005 § D.3 (HA): run the k0s controller as a schedulable worker too, so
    # the kube-vip DaemonSet — which selects control-plane Nodes — has a Node to
    # land on. A controller-only k0s node registers no kubelet/Node, so the
    # DaemonSet would stay Pending and the VIP would never float (Phase-4 lab
    # finding). k0s auto-applies the node-role.kubernetes.io/control-plane:NoSchedule
    # taint with --enable-worker; the DaemonSet tolerates it and general workloads
    # stay off. HA + CAPV/CAPM3 only — single-node (RenderKubeVIP=false) and CAPK
    # (OQ-5) never reach this, so their rendering is byte-for-byte unchanged.
    - --enable-worker
  {{- end }}
  {{- if and .ProviderID (not .Metal3) }}
    # KD-3c: tell kubelet the providerID BEFORE the Node is registered so it
    # appears in spec.providerID from first registration. The PR-8 audit
    # surfaced that k0s would otherwise register the Node and the
    # post-bootstrap kubectl patch would race the immutable-once-set
    # ProviderID. Mirrors the k3s ExecStartPre pattern. Validator at
    # internal/bootstrap/validate.go pins ProviderID to a strict regex,
    # so direct interpolation here is safe (no shell injection surface).
    # Not emitted for Metal3: CAPM3 owns Node.spec.providerID (ADR 0004).
    - --kubelet-extra-args=--provider-id={{ .ProviderID }}
  {{- end }}
  {{- end }}

{{- else }}

# Worker node configuration
k0s-worker:
  enabled: true
  args:
    - --token-file /etc/k0s/token
    {{- if and .ProviderID (not .Metal3) }}
    # KD-3c: same providerID-at-startup story as the control-plane block above.
    # Not emitted for Metal3: CAPM3 owns Node.spec.providerID (ADR 0004).
    - --kubelet-extra-args=--provider-id={{ .ProviderID }}
    {{- end }}

{{- end }}

write_files:
  - path: /system/oem/12_kairos-capi-persistency.yaml
    permissions: "0644"
    owner: root
    group: root
    content: |
{{ persistencyOEM | indent 6 }}
  {{- /*
    HA-init nodes always emit /etc/k0s/k0s.yaml so the apiserver cert covers the
    stable control-plane endpoint (api.sans). The pre-existing CIDR-only path is
    preserved byte-for-byte: when not an init node, the gate and body are exactly
    as before (.IsInitControlPlane is false for single/join/worker/empty role).
  */ -}}
  {{- $haSans := and .IsInitControlPlane .ManagementEndpoint .ManagementEndpoint.ControlPlaneEndpointHost }}
  {{- if and (eq .Role "control-plane") (or .PodCIDR .ServiceCIDR $haSans) }}
  - path: /etc/k0s/k0s.yaml
    permissions: "0644"
    content: |
      apiVersion: k0s.k0sproject.io/v1beta1
      kind: ClusterConfig
      metadata:
        name: k0s
      {{- if or .PodCIDR .ServiceCIDR $haSans }}
      spec:
      {{- if $haSans }}
        api:
          sans:
            - {{ .ManagementEndpoint.ControlPlaneEndpointHost | quote }}
      {{- end }}
      {{- if or .PodCIDR .ServiceCIDR }}
        network:
      {{ if .PodCIDR }}
          podCIDR: {{ .PodCIDR | quote }}
      {{ end }}
      {{ if .ServiceCIDR }}
          serviceCIDR: {{ .ServiceCIDR | quote }}
      {{ end }}
      {{- end }}
      {{- else }}
      spec: {}
      {{- end }}
  {{- end }}
  {{- if .IsJoinControlPlane }}
  # ADR 0005 (HA) join node: k0s controller-role join token. Sourced from
  # .JoinToken, which the Phase-3 controller produces on the init controller
  # (k0s token create --role=controller) and delivers over the node-push channel
  # (TOKEN-INV). Phase 2 renders it given the input; empty until Phase 3.
  # 0600: this is a controller-join secret on disk.
  - path: /etc/k0s/controller-token
    permissions: "0600"
    owner: root
    group: root
    content: |
      {{ .JoinToken }}
  {{- end }}
  {{- if .RenderKubeVIP }}
  # ADR 0005 § D.1 (HA) kube-vip DaemonSet + RBAC (CAPV/CAPM3 only; CAPK uses its
  # built-in LoadBalancer Service per OQ-5 and never reaches this block).
  # k0s applies manifests under /var/lib/k0s/manifests/<dir>/ via its
  # manifest-deployer (stack applier). The manifest is a multi-document set
  # (ServiceAccount + ClusterRole + ClusterRoleBinding + DaemonSet) produced by
  # kubeVIPManifest (marshaled YAML, VIP-INV-2) — no operator string is
  # concatenated into the YAML. The DaemonSet runs one kube-vip per control-plane
  # Node; the instances leader-elect on the plndr-cp-lock Lease (hence the RBAC)
  # and the leader ARPs the floating control-plane VIP, so VIP ownership fails
  # over when the leader's Node dies.
  - path: /var/lib/k0s/manifests/kube-vip/kube-vip.yaml
    permissions: "0644"
    owner: root
    group: root
    content: |
{{ kubeVIPManifest .VIP | indent 6 }}
  {{- end }}
  {{- if and (ne .Role "control-plane") .WorkerToken }}
  - path: /etc/k0s/token
    permissions: "0644"
    content: |
      {{ .WorkerToken }}
  {{- end }}
  {{- /*
    Post-bootstrap unit + script writes were previously emitted via
    stages.initramfs.files. Lab validation against Hadron installer images
    (kairos-hadron-k0s-rootdisk DV) revealed that files written under
    stages.initramfs.files do NOT persist on the installed Hadron rootfs —
    the initramfs phase runs before the persistent layer is mounted on that
    image stack, so the writes vanish on first boot. Moving them to
    top-level write_files: persists on both Hadron and Ubuntu-Kairos.
  */ -}}
  {{- if or .Hostname .HostnamePrefix }}
  - path: /usr/local/etc/hostname
    permissions: "0644"
    owner: root
    group: root
    content: |
      {{- if .Hostname }}
      {{ .Hostname }}
      {{- else }}
      {{ .HostnamePrefix }}{{ "{{ trunc 4 .MachineID }}" }}
      {{- end }}
  {{- end }}
  - path: /etc/systemd/system/kairos-k0s-post-bootstrap.service
    permissions: "0644"
    owner: root
    group: root
    content: |
      [Unit]
      Description=Kairos k0s post-bootstrap tasks
      # Skip on Kairos live installer (cdroot present in cmdline) — the
      # post-bootstrap script would block for 7+ minutes waiting for k0s
      # node registration that never happens on the installer, holding
      # up cloud-init's runcmd and preventing kairos-agent from rebooting
      # into the installed system. (KD-3b lab finding on Hadron.)
      ConditionKernelCommandLine=!cdroot
      {{- if eq .Role "control-plane" }}
      After=k0s.service
      Wants=k0s.service
      {{- else }}
      After=k0s-worker.service
      Wants=k0s-worker.service
      {{- end }}

      [Service]
      Type=oneshot
      RemainAfterExit=yes
      ExecStart=/usr/local/bin/kairos-k0s-post-bootstrap.sh

      [Install]
      WantedBy=multi-user.target
  - path: /etc/systemd/system/kairos-k0s-post-bootstrap-enable.service
    permissions: "0644"
    owner: root
    group: root
    content: |
      [Unit]
      Description=Enable kairos-k0s-post-bootstrap service
      # Skip on live installer; pairs with the same gate on the main
      # post-bootstrap service. (KD-3b.)
      ConditionKernelCommandLine=!cdroot
      After=systemd-udev-settle.service
      Before=multi-user.target

      [Service]
      Type=oneshot
      RemainAfterExit=yes
      ExecStart=/bin/systemctl daemon-reload
      # `enable --now`: create the multi-user.target.wants/ symlink AND
      # start the unit on this boot. After the KD-3b write_files move,
      # the main service file lands on disk during cloud-init early boot;
      # this helper runs once multi-user.target is set up and triggers
      # both enablement and immediate start of the post-bootstrap service.
      ExecStart=/bin/systemctl enable --now kairos-k0s-post-bootstrap.service
      {{- if .IsHAControlPlane }}
      # ADR 0005 §E.3: on HA control-plane nodes, also enable the etcd-leave
      # responder timer so the node can cleanly `k0s etcd leave` when the
      # controller requests it during a quorum-safe replacement/scale-down.
      ExecStart=/bin/systemctl enable --now kairos-etcd-leave.timer
      {{- end }}

      [Install]
      WantedBy=multi-user.target
  {{- if .IsHAControlPlane }}
  # ADR 0005 §E.3 (HA) k0s etcd-leave responder. During a quorum-safe
  # replacement/scale-down the controller (a) sets a CAPI pre-terminate hook on
  # this Machine and (b) writes a `leave-requested` sentinel for this member into
  # the workload-cluster kube-system/kairos-etcd-leave ConfigMap. This node-local
  # timer polls that ConfigMap via the LOCAL admin.conf (no mgmt token — the
  # node's mgmt bearer token is only valid ~24h, but replacement happens much
  # later; the local kubeconfig never expires), and on the exact sentinel runs
  # `k0s etcd leave` (which leaves THIS node — no operator/ConfigMap value is
  # ever passed as a command argument), then acks `left`. The controller then
  # clears the pre-terminate hook and CAPI terminates the VM.
  - path: /usr/local/bin/kairos-etcd-leave.sh
    permissions: "0755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -euo pipefail
      # This member's key == the sanitized hostname, identical to the reporter's
      # key so it matches what the controller writes (the node's Kubernetes Node
      # name == NodeRef.Name). Strip hostname's trailing newline BEFORE the
      # complement-translate, or it becomes a spurious trailing '-' that no
      # longer matches NodeRef.Name.
      member_key=$(hostname | tr -d '\n' | tr -c 'a-zA-Z0-9._-' '-')
      # Read our own leave signal from the workload ConfigMap via the LOCAL admin
      # kubeconfig (k0s kubectl). Absent ConfigMap/key => empty => no-op exit.
      val=$(k0s kubectl -n kube-system get configmap kairos-etcd-leave -o "jsonpath={.data.${member_key}}" 2>/dev/null || true)
      # Fixed sentinel, string-equality only — never eval'd, never a command arg.
      [ "${val}" = "leave-requested" ] || exit 0
      echo "etcd-leave: leave requested for ${member_key}; leaving etcd cluster"
      # `k0s etcd leave` (no --peer-address) leaves THIS node using its own
      # configured peer address — no ConfigMap/operator-derived value reaches the
      # command (security constraint: peer-address is never externally supplied).
      if k0s etcd leave 2>/dev/null; then
        echo "etcd-leave: left etcd cluster"
      else
        echo "etcd-leave: k0s etcd leave returned non-zero (already left?); acking anyway"
      fi
      # Ack by patching our own key to `left`. Only member_key (locally
      # sanitized) is interpolated; the read-back value is never reused.
      k0s kubectl -n kube-system patch configmap kairos-etcd-leave --type merge \
        -p "{\"data\":{\"${member_key}\":\"left\"}}" 2>/dev/null || true
  - path: /etc/systemd/system/kairos-etcd-leave.service
    permissions: "0644"
    owner: root
    group: root
    content: |
      [Unit]
      Description=Kairos k0s etcd-leave responder (ADR 0005 §E.3)
      ConditionKernelCommandLine=!cdroot
      After=k0s.service
      Wants=k0s.service

      [Service]
      Type=oneshot
      ExecStart=/usr/local/bin/kairos-etcd-leave.sh
  - path: /etc/systemd/system/kairos-etcd-leave.timer
    permissions: "0644"
    owner: root
    group: root
    content: |
      [Unit]
      Description=Poll for Kairos k0s etcd-leave requests (ADR 0005 §E.3)
      ConditionKernelCommandLine=!cdroot

      [Timer]
      OnBootSec=60
      OnUnitActiveSec=30

      [Install]
      WantedBy=timers.target
  {{- end }}
  - path: /usr/local/bin/kairos-k0s-post-bootstrap.sh
    permissions: "0755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -e

      {{- if .HostnamePrefix }}
      # Enforce hostname from cloud-config on immutable rootfs
      if [ -f /usr/local/etc/hostname ]; then
        /usr/bin/hostnamectl set-hostname "$(cat /usr/local/etc/hostname)"
        if ! grep -qE "127\.0\.1\.1[[:space:]]+$(cat /usr/local/etc/hostname)" /etc/hosts; then
          echo "127.0.1.1 $(cat /usr/local/etc/hostname)" >> /etc/hosts
        fi
      fi
      {{- end }}

      {{- if .Manifests }}
      # Write k0s manifests
      echo "Writing k0s manifests..."
      mkdir -p /var/lib/k0s/manifests
      {{- range .Manifests }}
      mkdir -p /var/lib/k0s/manifests/{{ .Name }}
      cat > /var/lib/k0s/manifests/{{ .Name }}/{{ .File }} << 'MANIFEST_EOF'
{{ .Content }}
MANIFEST_EOF
      chmod 0644 /var/lib/k0s/manifests/{{ .Name }}/{{ .File }}
      echo "Written manifest: /var/lib/k0s/manifests/{{ .Name }}/{{ .File }}"
      {{- end }}
      {{- end }}

      {{- if and .ProviderID (not .Metal3) }}
      # Wait for k0s to be ready and the Node to be registered, then set providerID.
      # KD-55: fail-OPEN. A providerID hiccup (API blip, slow registration) must NOT
      # abort the rest of post-bootstrap — the kubeconfig push below MUST still run,
      # or a transient failure strands the cluster in WaitingForNodePush forever.
      # Warn and continue instead of `exit 1`; the Machine may briefly stay
      # NodeNotFound until providerID is set, but the kubeconfig still reaches the
      # management cluster (and the controller re-renders to retry providerID).
      echo "Waiting for k0s node to be registered..."
      # Use `k0s kubectl` (resolves the local admin kubeconfig). The Hadron k0s
      # image ships no standalone `kubectl` binary, so bare `kubectl` would fail
      # `command not found` (swallowed by &>/dev/null) and silently never set the
      # providerID — lab-confirmed. Mirrors the Metal3 path below.
      node_registered=false
      MAX_WAIT=300
      ELAPSED=0
      while [ $ELAPSED -lt $MAX_WAIT ]; do
        if k0s kubectl get node $(hostname) &>/dev/null; then
          node_registered=true
          break
        fi
        echo "Waiting for node to be registered... (${ELAPSED}s/${MAX_WAIT}s)"
        sleep 5
        ELAPSED=$((ELAPSED + 5))
      done
      if [ "$node_registered" != "true" ]; then
        echo "WARN: timed out waiting for Node registration; skipping providerID (continuing post-bootstrap)"
      else
        # Set providerID on the Node. Retry for transient API-server unavailability.
        echo "Setting providerID={{ .ProviderID }} on node $(hostname)..."
        PROVIDER_ID_SET=false
        for i in {1..30}; do
          if k0s kubectl patch node $(hostname) --type=merge -p '{"spec":{"providerID":"{{ .ProviderID }}"}}' &>/dev/null; then
            echo "Successfully set providerID={{ .ProviderID }} on node $(hostname)"
            PROVIDER_ID_SET=true
            break
          fi
          echo "Attempt $i/30: Failed to set providerID, retrying in 5 seconds..."
          sleep 5
        done
        if [ "$PROVIDER_ID_SET" != "true" ]; then
          echo "WARN: failed to set providerID after 30 attempts; continuing post-bootstrap (Machine may stay NodeNotFound until providerID is set)"
        fi
      fi
      {{- else if not .Metal3 }}
      # CAPV self-discovery: ProviderID was not available at render time (assigned
      # after VM clone), so compute vsphere://<uuid> from DMI at boot.
      # KD-55: fail-OPEN. If the UUID is absent or malformed, warn and continue so
      # the kubeconfig push below still runs. A missing providerID is recoverable;
      # a stranded cluster is not.
      # DMI uses mixed-endian byte order for the first three UUID groups; vSphere
      # expects RFC/ISO big-endian. The byte-swap below is the same algorithm
      # proven correct in the k3s CAPV template (lab-validated: discovered UUID
      # matched VSphereMachine providerID and Machine reached Running).
      export KUBECONFIG=/var/lib/k0s/pki/admin.conf
      PROVIDER_ID=""
      if [ -f /sys/class/dmi/id/product_uuid ]; then
        RAW=$(cat /sys/class/dmi/id/product_uuid | tr -d ' \n\r')
        HEX=$(echo "$RAW" | tr -d '-' | tr '[:upper:]' '[:lower:]')
        if [ -n "$HEX" ] && [ ${#HEX} -eq 32 ]; then
          T0="${HEX:6:2}${HEX:4:2}${HEX:2:2}${HEX:0:2}"
          T1="${HEX:10:2}${HEX:8:2}"
          T2="${HEX:14:2}${HEX:12:2}"
          REST="${HEX:16:16}"
          FORMATTED="${T0}-${T1}-${T2}-${REST:0:4}-${REST:4:12}"
          # Strict UUID validation before the kubectl patch. The validated value
          # is interpolated into a JSON string in -p below; enforcing the regex
          # here closes the injection surface (malformed input never reaches the
          # patch). Whole-string match via bash =~ (not line-anchored grep).
          UUID_RE='^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'
          if [[ "${FORMATTED}" =~ ${UUID_RE} ]]; then
            PROVIDER_ID="vsphere://${FORMATTED}"
            echo "Discovered providerID from DMI: ${PROVIDER_ID}"
          else
            echo "WARN: DMI UUID '${FORMATTED}' did not match UUID pattern; skipping providerID (continuing post-bootstrap)"
          fi
        else
          echo "WARN: DMI product_uuid is absent or not 32 hex chars after strip; skipping providerID (continuing post-bootstrap)"
        fi
      else
        echo "WARN: /sys/class/dmi/id/product_uuid not found; skipping providerID (continuing post-bootstrap)"
      fi
      if [ -n "${PROVIDER_ID}" ]; then
        echo "Waiting for k0s node to be registered..."
        node_registered=false
        MAX_WAIT=300
        ELAPSED=0
        while [ $ELAPSED -lt $MAX_WAIT ]; do
          # k0s kubectl: the Hadron k0s image has no standalone `kubectl` binary.
          if k0s kubectl get node $(hostname) &>/dev/null; then
            node_registered=true
            break
          fi
          echo "Waiting for node to be registered... (${ELAPSED}s/${MAX_WAIT}s)"
          sleep 5
          ELAPSED=$((ELAPSED + 5))
        done
        if [ "$node_registered" != "true" ]; then
          echo "WARN: timed out waiting for Node registration; skipping providerID (continuing post-bootstrap)"
        else
          # Set the discovered providerID on the Node. Retry for transient API-server unavailability.
          echo "Setting providerID=${PROVIDER_ID} on node $(hostname)..."
          PROVIDER_ID_SET=false
          for i in {1..30}; do
            if k0s kubectl patch node $(hostname) --type=merge -p "{\"spec\":{\"providerID\":\"${PROVIDER_ID}\"}}" &>/dev/null; then
              echo "Successfully set providerID=${PROVIDER_ID} on node $(hostname)"
              PROVIDER_ID_SET=true
              break
            fi
            echo "Attempt $i/30: Failed to set providerID, retrying in 5 seconds..."
            sleep 5
          done
          if [ "$PROVIDER_ID_SET" != "true" ]; then
            echo "WARN: failed to set providerID after 30 attempts; continuing post-bootstrap (Machine may stay NodeNotFound until providerID is set)"
          fi
        fi
      fi
      {{- end }}

      {{- if .Metal3 }}
      {{- if eq .Role "control-plane" }}
      # Metal3 / CAPM3 providerID + node-label (post-bootstrap patch). REDESIGNED
      # after the k0s lab e2e (ADR 0004): the previous pre-start ExecStart-injection
      # oneshot is unworkable on k0s. k0scontroller is started by the Kairos provider
      # BEFORE cloud-config runs, so a boot-stage `systemctl enable` only arms a
      # WantedBy symlink for a k0s start that never comes (the unit never runs); and a
      # Before=k0scontroller oneshot that restarts the k0s service to apply the change
      # deadlocks (systemd ordering cycle — confirmed on the node, apiserver stuck down).
      #
      # CAPM3 v1.13 (cloudProviderEnabled:false) selects the Node by the metal3.io/uuid
      # label and VALIDATES Node.spec.providerID == metal3://<uuid>; it does not set
      # them. Setting a PREVIOUSLY-EMPTY providerID is permitted by the apiserver
      # (immutability only guards a non-empty value), so we patch it here, reusing the
      # same admin.conf-based post-bootstrap patch the non-Metal3 path above uses. This
      # runs inside the already-enabled kairos-k0s-post-bootstrap.service: no extra
      # unit, no Before=, no restart, no deadlock, no Node-registration race.
      # Control-plane only — admin.conf is CP-only and Metal3 is single-node-CP this
      # release (replicas > 1 is webhook-rejected; k0s Metal3 workers are a future item).
      set_metal3_providerid() {
        # Read + validate the BMH UUID from the Ironic config-drive (config-2 /
        # /openstack/latest/meta_data.json). This is the ONLY trusted source; mount
        # it read-only (nodev,nosuid,noexec) and FAIL-CLOSED (skip, leaving the Node
        # unpatched) on any missing/malformed value rather than ever writing a garbage
        # provider-id. Do NOT fall back to cloud-init paths (Kairos uses yip; a stale
        # instance-data file would yield a WRONG-but-valid UUID).
        local cfgdev="" cfgmount=/run/metal3-cfgdrive mounted_here=false meta_json uuid=""
        if blkid -L config-2 &>/dev/null; then
          cfgdev=$(blkid -L config-2)
        elif [ -b /dev/disk/by-label/config-2 ]; then
          cfgdev=/dev/disk/by-label/config-2
        fi
        if [ -n "${cfgdev}" ]; then
          mkdir -p "${cfgmount}"
          if mount -o ro,nodev,nosuid,noexec "${cfgdev}" "${cfgmount}" 2>/dev/null; then
            mounted_here=true
          fi
        fi
        meta_json="${cfgmount}/openstack/latest/meta_data.json"
        if [ ! -f "${meta_json}" ]; then
          echo "WARN: metal3-providerid: ${meta_json} not found (config-drive 'config-2' present+mounted?); skipping (fail-closed)"
          [ "${mounted_here}" = true ] && umount "${cfgmount}" 2>/dev/null || true
          return 0
        fi
        if command -v jq &>/dev/null; then
          uuid=$(jq -r '.uuid // empty' "${meta_json}" 2>/dev/null || true)
        else
          uuid=$(grep -oE '"uuid"[[:space:]]*:[[:space:]]*"[^"]+"' "${meta_json}" 2>/dev/null | head -1 | sed 's/.*"uuid"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || true)
        fi
        [ "${mounted_here}" = true ] && umount "${cfgmount}" 2>/dev/null || true
        # Whole-string validation: reject any value with a character outside [hex,dash]
        # (newlines, spaces, '=', ',', '/', shell/JSON metachars — closes provider-id/
        # label-value injection and the multi-line bypass), then enforce the exact UUID
        # shape (string-anchored, not line-anchored).
        local uuid_re='^[0-9a-fA-F]{8}-([0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}$'
        case "${uuid}" in
          "" | *[!0-9a-fA-F-]* )
            echo "WARN: metal3-providerid: extracted UUID is empty or contains illegal characters; skipping (fail-closed)"
            return 0 ;;
        esac
        if ! [[ "${uuid}" =~ ${uuid_re} ]]; then
          echo "WARN: metal3-providerid: extracted UUID '${uuid}' does not match UUID pattern; skipping (fail-closed)"
          return 0
        fi
        # Wait for the Node to register, then set provider-id + the metal3.io/uuid
        # label. LEGACY metal3://<uuid> format (accepted by CAPM3 v1.13; the new
        # metal3://<ns>/<bmh>/<m3m> form is not derivable from config-drive metadata).
        # ${uuid} is a validated bare hex/dash UUID, so interpolation into the patch
        # JSON is injection-safe. Use `k0s kubectl` (resolves the local admin kubeconfig).
        local desired="metal3://${uuid}" w=0 cur
        while ! k0s kubectl get node "$(hostname)" &>/dev/null; do
          if [ ${w} -ge 300 ]; then
            echo "WARN: metal3-providerid: timed out waiting for Node registration; skipping"
            return 0
          fi
          sleep 5; w=$((w + 5))
        done
        for i in $(seq 1 30); do
          cur=$(k0s kubectl get node "$(hostname)" -o jsonpath='{.spec.providerID}' 2>/dev/null || true)
          if [ "${cur}" = "${desired}" ]; then
            echo "metal3-providerid: Node $(hostname) already has provider-id=${desired}; ensuring label"
            k0s kubectl label node "$(hostname)" "metal3.io/uuid=${uuid}" --overwrite &>/dev/null || true
            return 0
          fi
          if [ -n "${cur}" ]; then
            echo "WARN: metal3-providerid: Node $(hostname) has a different non-empty provider-id '${cur}'; not overwriting (immutable)"
            return 0
          fi
          if k0s kubectl patch node "$(hostname)" --type=merge \
               -p "{\"spec\":{\"providerID\":\"${desired}\"},\"metadata\":{\"labels\":{\"metal3.io/uuid\":\"${uuid}\"}}}" &>/dev/null; then
            echo "metal3-providerid: set provider-id=${desired} + metal3.io/uuid=${uuid} on Node $(hostname)"
            return 0
          fi
          echo "metal3-providerid: attempt ${i}/30 to patch Node failed; retrying in 5s..."
          sleep 5
        done
        echo "WARN: metal3-providerid: failed to set provider-id after 30 attempts; CAPM3 will not bind until it is set"
        return 0
      }
      # Called with `|| true` so a failure here never aborts the rest of post-bootstrap
      # (kubeconfig push etc.). bash also suppresses `set -e` inside a function invoked
      # in a `||` list, so the function's internal fail-closed `return 0`s are the
      # control flow and a stray command error cannot kill the node bring-up.
      set_metal3_providerid || echo "WARN: metal3-providerid: step errored; continuing post-bootstrap"
      {{- else }}
      # Metal3 k0s WORKER providerID is not supported in this release: a worker has no
      # local admin.conf to patch and k0s has no config.yaml.d kubelet-arg drop-in.
      # Metal3 is single-node control-plane only (replicas > 1 is webhook-rejected).
      {{- end }}
      {{- end }}

      {{- if .ManagementEndpoint }}
      # Push kubeconfig to management cluster without SSH (KD-3b).
      # Mirrors the CAPK push block; CAPV has no LB Service so the
      # `server:` URL is rewritten to the cluster's controlPlaneEndpoint
      # host (set by the infrastructure provider) instead of an LB IP.
      push_kubeconfig() {
        local kubeconfig_file="/var/lib/k0s/pki/admin.conf"
        # Wait up to 5min for k0s to write admin.conf. After=k0s.service only
        # orders against service activation, not bootstrap completion, so on
        # slower hosts (Hadron+CAPV lab finding) the file is not yet present
        # when this unit fires. Without this wait the unit silently abandons
        # the push and KCP stays in WaitingForNodePush forever (KD-3b).
        local _wait_budget=300
        local _wait_elapsed=0
        while [ ! -f "${kubeconfig_file}" ] && [ ${_wait_elapsed} -lt ${_wait_budget} ]; do
          sleep 5
          _wait_elapsed=$((_wait_elapsed + 5))
        done
        if [ ! -f "${kubeconfig_file}" ]; then
          echo "WARN: kubeconfig file not found at ${kubeconfig_file} after ${_wait_budget}s"
          return 1
        fi
        if ! command -v curl >/dev/null 2>&1; then
          echo "WARN: curl not available; cannot push kubeconfig"
          return 1
        fi
        if ! command -v base64 >/dev/null 2>&1; then
          echo "WARN: base64 not available; cannot push kubeconfig"
          return 1
        fi
        local kubeconfig_b64
        {{- if .ManagementEndpoint.ControlPlaneEndpointHost }}
        local tmp_kubeconfig
        tmp_kubeconfig=$(mktemp)
        local cp_endpoint_host={{ .ManagementEndpoint.ControlPlaneEndpointHost | shquote }}
        sed "s|https://[^[:space:]]*:6443|https://${cp_endpoint_host}:6443|g" "${kubeconfig_file}" > "${tmp_kubeconfig}"
        kubeconfig_b64=$(base64 -w 0 "${tmp_kubeconfig}" 2>/dev/null || base64 "${tmp_kubeconfig}" | tr -d '\n')
        rm -f "${tmp_kubeconfig}"
        {{- else }}
        kubeconfig_b64=$(base64 -w 0 "${kubeconfig_file}" 2>/dev/null || base64 "${kubeconfig_file}" | tr -d '\n')
        {{- end }}
        local api={{ .ManagementEndpoint.APIServer | shquote }}
        local ns={{ .ManagementEndpoint.KubeconfigSecretNamespace | shquote }}
        local name={{ .ManagementEndpoint.KubeconfigSecretName | shquote }}
        local token={{ .ManagementEndpoint.Token | shquote }}
        local cluster_name={{ .ManagementEndpoint.ClusterName | shquote }}
        local payload
        payload="{\"apiVersion\":\"v1\",\"kind\":\"Secret\",\"metadata\":{\"name\":\"${name}\",\"namespace\":\"${ns}\",\"labels\":{\"cluster.x-k8s.io/cluster-name\":\"${cluster_name}\"},\"annotations\":{\"controllers.cluster.x-k8s.io/kubeconfig-source\":\"node-push\"}},\"type\":\"cluster.x-k8s.io/secret\",\"data\":{\"value\":\"${kubeconfig_b64}\"}}"
        local url="${api}/api/v1/namespaces/${ns}/secrets/${name}"
        local status
        status=$(curl -k -sS -o /tmp/kairos-kubeconfig-push.log -w "%{http_code}" \
          -H "Authorization: Bearer ${token}" \
          -H "Content-Type: application/json" \
          -X PUT \
          --data "${payload}" \
          "${url}" || true)
        if [ "${status}" = "404" ]; then
          status=$(curl -k -sS -o /tmp/kairos-kubeconfig-push.log -w "%{http_code}" \
            -H "Authorization: Bearer ${token}" \
            -H "Content-Type: application/json" \
            -X POST \
            --data "${payload}" \
            "${api}/api/v1/namespaces/${ns}/secrets" || true)
        fi
        if [ "${status}" -ge 200 ] && [ "${status}" -lt 300 ]; then
          echo "Pushed kubeconfig to management secret ${ns}/${name}"
          return 0
        fi
        echo "WARN: failed to push kubeconfig to management cluster (status ${status})"
        return 1
      }
      if ! push_kubeconfig; then
        echo "WARN: kubeconfig push failed; proceeding without blocking bootstrap"
      fi
      {{- end }}

      {{- if and .IsInitControlPlane .ManagementEndpoint .ManagementEndpoint.JoinTokenSecretName }}
      # ADR 0005 (HA) k0s init node: mint the controller-role join token and push
      # it to the management cluster over the SAME node-push channel as the
      # kubeconfig (NOT SSH — KD-3b / OQ-2). The k0s controller-join token does
      # not exist until k0s is up, so the controller cannot pre-generate it (as it
      # does for k3s); the init node creates it here and PUTs it into the
      # pre-created, owner-ref'd join-token Secret. Joiners then resolve it via
      # ControlPlaneJoinTokenSecretRef and the controller's joiner gate opens.
      #
      # SECURITY (TOKEN-INV): the token is captured into a shell var and
      # base64-enveloped into the Secret data — it is NEVER interpolated through
      # text/template, NEVER echoed, and NEVER logged. All management-endpoint
      # values are shquote'd (single-quoted POSIX literals; no shell evaluation),
      # identical to the kubeconfig push above.
      push_join_token() {
        if ! command -v curl >/dev/null 2>&1; then
          echo "WARN: curl not available; cannot push join token"
          return 1
        fi
        if ! command -v base64 >/dev/null 2>&1; then
          echo "WARN: base64 not available; cannot push join token"
          return 1
        fi
        local jt
        # Long expiry so the token stays valid across the whole HA join window.
        jt=$(k0s token create --role=controller --expiry=24h 2>/dev/null || true)
        if [ -z "${jt}" ]; then
          echo "WARN: k0s token create returned empty; will retry on next boot"
          return 1
        fi
        local jt_b64
        jt_b64=$(printf '%s' "${jt}" | base64 -w 0 2>/dev/null || printf '%s' "${jt}" | base64 | tr -d '\n')
        # Scrub the plaintext token from the shell as soon as it is enveloped.
        unset jt
        local api={{ .ManagementEndpoint.APIServer | shquote }}
        local ns={{ .ManagementEndpoint.KubeconfigSecretNamespace | shquote }}
        local jt_name={{ .ManagementEndpoint.JoinTokenSecretName | shquote }}
        local token={{ .ManagementEndpoint.Token | shquote }}
        local cluster_name={{ .ManagementEndpoint.ClusterName | shquote }}
        # PATCH the pre-existing (controller-created, owner-ref'd) Secret's
        # data.token via a strategic-merge patch. The Secret already exists and is
        # owned by the KCP, so we only ever update data — never create — which is
        # exactly the RBAC the node SA is granted (update/patch on the named
        # join-token Secret, no create).
        local patch
        patch="{\"data\":{\"token\":\"${jt_b64}\"}}"
        local url="${api}/api/v1/namespaces/${ns}/secrets/${jt_name}"
        local status
        status=$(curl -k -sS -o /tmp/kairos-jointoken-push.log -w "%{http_code}" \
          -H "Authorization: Bearer ${token}" \
          -H "Content-Type: application/strategic-merge-patch+json" \
          -X PATCH \
          --data "${patch}" \
          "${url}" || true)
        # Scrub the enveloped token too.
        unset jt_b64 patch
        if [ "${status}" -ge 200 ] && [ "${status}" -lt 300 ]; then
          echo "Pushed controller-join token to management secret ${ns}/${jt_name}"
          return 0
        fi
        echo "WARN: failed to push controller-join token (status ${status})"
        return 1
      }
      if ! push_join_token; then
        echo "WARN: controller-join token push failed; joiners will wait until it succeeds"
      fi
      {{- end }}

      {{- if and .IsHAControlPlane .ManagementEndpoint .ManagementEndpoint.EtcdStatusSecretName }}
      # ADR 0005 §E.1 (HA) etcd-health reporter: every control-plane node (init
      # AND join) reports its own etcd member health into the per-cluster
      # etcd-status Secret over the SAME node-push channel as the kubeconfig/join
      # token (NOT SSH, NOT a controller etcd dial — KD-10). The controller reads
      # it for the joiner gate (init must be a healthy voting member),
      # EtcdHealthyCondition, and the quorum-safe-replacement guard.
      #
      # SECURITY: etcd membership (name/count) is non-sensitive cluster metadata —
      # NO secret material is written into this Secret. The status JSON is built
      # ON-NODE (never interpolated through text/template); every
      # management-endpoint value is shquote'd; the bearer token is never logged.
      # The node PATCHes ONLY its own member key (keyed by hostname).
      push_etcd_status() {
        if ! command -v curl >/dev/null 2>&1; then
          echo "WARN: curl not available; cannot report etcd status"
          return 1
        fi
        if ! command -v base64 >/dev/null 2>&1; then
          echo "WARN: base64 not available; cannot report etcd status"
          return 1
        fi
        # This member's Secret data key = the node hostname, sanitized to the
        # allowed Secret-key charset [a-zA-Z0-9._-] so it is safe both as a
        # Secret key and inside the strategic-merge patch JSON.
        local member_key
        # Strip hostname's trailing newline BEFORE the complement-translate, or
        # it becomes a spurious trailing '-'; the key must equal the node's
        # Kubernetes Node name (NodeRef.Name) that the controller looks up.
        member_key=$(hostname | tr -d '\n' | tr -c 'a-zA-Z0-9._-' '-')
        # Query k0s etcd membership. k0s controllers join as full voting members
        # (no learners), so "present in member-list" == "healthy voting member".
        local ml healthy=false voting=false members=0
        ml=$(k0s etcd member-list 2>/dev/null || true)
        if [ -n "${ml}" ]; then
          healthy=true
          voting=true
          members=$(printf '%s' "${ml}" | grep -oE 'https?://' | wc -l | tr -d ' ')
        fi
        local reported_at
        reported_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
        # Compact, non-secret status JSON for THIS member, built on-node.
        local status_json
        status_json=$(printf '{"name":"%s","healthy":%s,"voting":%s,"members":%s,"reportedAt":"%s"}' \
          "${member_key}" "${healthy}" "${voting}" "${members}" "${reported_at}")
        local status_b64
        status_b64=$(printf '%s' "${status_json}" | base64 -w 0 2>/dev/null || printf '%s' "${status_json}" | base64 | tr -d '\n')
        local api={{ .ManagementEndpoint.APIServer | shquote }}
        local ns={{ .ManagementEndpoint.KubeconfigSecretNamespace | shquote }}
        local es_name={{ .ManagementEndpoint.EtcdStatusSecretName | shquote }}
        local token={{ .ManagementEndpoint.Token | shquote }}
        # Strategic-merge PATCH only this member's own data key in the pre-created,
        # Cluster-owned etcd-status Secret. update/patch on the named Secret is
        # exactly the node SA's RBAC (no create).
        local patch
        patch="{\"data\":{\"${member_key}\":\"${status_b64}\"}}"
        local url="${api}/api/v1/namespaces/${ns}/secrets/${es_name}"
        local status
        status=$(curl -k -sS -o /tmp/kairos-etcdstatus-push.log -w "%{http_code}" \
          -H "Authorization: Bearer ${token}" \
          -H "Content-Type: application/strategic-merge-patch+json" \
          -X PATCH \
          --data "${patch}" \
          "${url}" || true)
        unset token
        if [ "${status}" -ge 200 ] && [ "${status}" -lt 300 ]; then
          echo "Reported etcd status to management secret ${ns}/${es_name} (member ${member_key})"
          return 0
        fi
        echo "WARN: failed to report etcd status (status ${status})"
        return 1
      }
      if ! push_etcd_status; then
        echo "WARN: etcd-status report failed; will retry on next boot"
      fi
      {{- end }}

      # Mark bootstrap success for CAPI/CAPK consumers
      # This file is used by Cluster API to determine bootstrap completion
      mkdir -p /run/cluster-api
      echo "success" > /run/cluster-api/bootstrap-success.complete
      chmod 0644 /run/cluster-api/bootstrap-success.complete

      echo "k0s post-bootstrap tasks completed successfully"
  {{- if .Files }}
  {{ toYaml .Files | nindent 2 }}
  {{- end }}

{{- /* DNS overrides */}}
stages:
  boot:
    - name: "Ensure SSH service is enabled"
      commands:
        - systemctl enable --now sshd || systemctl enable --now ssh || true
    {{- if .DNSServers }}
    - name: "Configure DNS resolvers for early boot"
      dns:
        nameservers:
        {{- range .DNSServers }}
          - {{ . | quote }}
        {{- end }}
        path: "/etc/resolv.conf"
    {{- end }}

{{- /*
  Post-bootstrap service enablement: kairos-k0s-post-bootstrap.service is
  enabled by kairos-k0s-post-bootstrap-enable.service. The previous
  symlink-via-`ln -sf` approach worked when the unit file was written by
  stages.initramfs.files (early boot, before multi-user.target was active).
  After moving the unit writes to top-level write_files for Hadron compat
  (KD-3b), runcmd executes too late in boot for systemd to re-scan
  multi-user.target.wants/, so the helper service never starts. Replace
  the manual symlink with `systemctl enable --now`: enable creates the
  multi-user symlink AND starts the helper service immediately on this boot.
*/}}
runcmd:
  # Enable + start the helper service explicitly. `enable --now` both
  # creates the multi-user.target.wants/ symlink for next boot AND starts
  # the unit on this boot. Required after KD-3b moved unit writes from
  # stages.initramfs.files to top-level write_files (runcmd is now too
  # late in boot for ln-only symlink creation to be honored by systemd).
  - /bin/systemctl daemon-reload || true
  - /bin/systemctl enable --now kairos-k0s-post-bootstrap-enable.service || true
